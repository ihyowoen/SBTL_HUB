# ===========================
# SBTL_HUB — Environment Variables
# ===========================
# Copy this file to .env.local for local dev, or set these in Vercel project settings.
# NEVER commit .env or .env.local — see .gitignore.
#
# IMPORTANT: Do NOT use VITE_ prefix for any secret/API key below.
# VITE_* env vars are injected into the client JS bundle and are publicly exposed.
# All API keys below are for server-side use only (api/*.js functions).

# --- Brave Search API (for /api/brave fallback) ---
# Get key: https://brave.com/search/api
BRAVE_KEY=

# --- Anthropic API (for compose.js LLM synthesis — S2 planned) ---
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- OpenAI API (for /api/analysis.js) ---
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
